{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@next-step/*": ["packages/*/src"]
    },
    "target": "ES2020",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM"]
  }
}
